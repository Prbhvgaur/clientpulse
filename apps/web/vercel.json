{
  "crons": [
    {
      "path": "/api/cron/sync-integrations",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/p/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=60, stale-while-revalidate=300"
        }
      ]
    }
  ]
}
